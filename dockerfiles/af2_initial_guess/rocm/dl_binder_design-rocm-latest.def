name: dl_binder_design-rocm-latest
base: ubuntu:24.04

build:
  context:
    - content: /app
      - type: bind

  - environment:
      - JAX_PLATFORMS: cpu

  - labels:
      version: "1.0"
      org.opencontainers.image.title: "Australian Protein Design Initiative - dl_binder_design (AMD ROCm)"
      org.opencontainers.image.source: https://github.com/nrbennet/dl_binder_design

setup:
  - copy:
    - files:
      - Dockerfile: Dockerfile
      - af2_initial_guess/: /app/af2_initial_guess
